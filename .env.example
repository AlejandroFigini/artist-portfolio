# ============================================================
#  artist-portfolio — variables de entorno
#  Copiá este archivo a `.env` y completá los valores.
#  La API vive dentro de Next (app/api/*). No hay backend Express aparte.
# ============================================================

# --- Base de datos (Postgres) -------------------------------
# PROD (Railway): pegá la URL del servicio Postgres (referencia interna o pública).
# LOCAL: tu Postgres local, ej:
#   postgresql://postgres:postgres@localhost:5432/artistportfolio
# Sin DATABASE_URL -> modo MOCK (no persiste; el front usa localStorage).
DATABASE_URL=

# --- Cloudinary (hosting de imágenes/videos) ----------------
# Completá SOLO en producción. En LOCAL dejalos VACÍOS -> las subidas se guardan
# en public/uploads (gitignoreado) y NO tocan Cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Usuarios / login (seed inicial) ------------------------
# 2 usuarios fijos, sembrados en DB al primer boot si la tabla users está
# vacía. Después cada uno cambia sus credenciales desde la UI (tuerca admin
# -> Mi cuenta) y activa su 2FA (QR propio); estas vars quedan solo como
# semilla inicial.
USER1_NAME=
USER1_PASS=
USER2_NAME=
USER2_PASS=
